      ],
      idempotency: [
        "why-idempotency",
        "duplicate-request-and-retry",
        "idempotency-key",
        "state-transition-and-unique-constraint",
        "message-consumer-idempotency",
        "payment-order-idempotency",
      ],
      performance: [
        "why-performance-problem",
        "latency-and-throughput",
        "bottleneck-analysis",
        "db-query-performance",
        "cache-performance",
        "connection-pool-and-timeout",
        "load-test-and-metrics",
      ],
      observability: [
        "why-observability",
        "logging",
        "metrics",
        "distributed-tracing",
        "trace-id-and-correlation-id",
        "alert-and-slo",
        "dashboard",
        "incident-analysis-flow",
      ],
    }

    if (a.isFolder !== b.isFolder) {
      return a.isFolder ? -1 : 1
    }

    const aParts = a.slug.split("/")
    const bParts = b.slug.split("/")
    const parentFolder = a.isFolder ? (aParts.at(-3) ?? "") : (aParts.at(-2) ?? "")
    const order = orderMap[parentFolder]

    if (order) {
      const aSlug = a.isFolder ? (aParts.at(-2) ?? "") : (aParts.at(-1) ?? "")
      const bSlug = b.isFolder ? (bParts.at(-2) ?? "") : (bParts.at(-1) ?? "")
      const aIdx = order.indexOf(aSlug)
      const bIdx = order.indexOf(bSlug)
      if (aIdx !== -1 && bIdx !== -1) return aIdx - bIdx
      if (aIdx !== -1) return -1
      if (bIdx !== -1) return 1
    }

    return a.displayName.localeCompare(b.displayName, undefined, {
      numeric: true,
      sensitivity: "base",
    })
  },
  mapFn: (node: FileTrieNode) => {
    const labels: Record<string, string> = {
      "00-home": "00 Home",
      "01-core": "01 Core",
      "02-practical-backend": "02 Practical Backend",
      "03-case-studies": "03 Case Studies",
      "04-interview": "04 Interview",
      "05-ai-workflows": "05 AI Workflows",
    }

    const segment = node.slugSegment ?? ""
    const label = labels[segment]

    if (label) {
      node.displayName = label
    }

    return node
  },
  order: ["filter", "sort", "map"],
})

const config = await loadQuartzConfig()

const quizRuntimeScript = `
function initializeQuizWidgets() {
  document.querySelectorAll("[data-quiz-card]").forEach((card) => {
    if (card.dataset.quizInitialized === "true") return
    card.dataset.quizInitialized = "true"

    const feedback = card.querySelector("[data-quiz-feedback]")
    const options = card.querySelectorAll("[data-quiz-option]")

    options.forEach((option) => {
      option.addEventListener("click", () => {
        const isCorrect = option.dataset.correct === "true"
        const explanation = option.dataset.explanation || ""

        options.forEach((item) => {
          item.classList.remove("is-selected", "is-correct", "is-incorrect")
          item.setAttribute("aria-pressed", "false")
        })

        option.classList.add("is-selected", isCorrect ? "is-correct" : "is-incorrect")
        option.setAttribute("aria-pressed", "true")

        if (feedback) {
          feedback.textContent = (isCorrect ? "정답: " : "오답: ") + explanation
          feedback.classList.toggle("is-correct", isCorrect)
          feedback.classList.toggle("is-incorrect", !isCorrect)
        }
      })
    })
  })
}

initializeQuizWidgets()
document.addEventListener("nav", initializeQuizWidgets)
`

config.plugins.emitters.push({
  name: "QuizRuntime",
  externalResources: () => ({
    js: [
      {
        loadTime: "afterDOMReady",
        contentType: "inline",
        script: quizRuntimeScript,
      },
    ],
  }),
  async *emit() {},
})

export default config
export const layout = await loadQuartzLayout()
