  filterFn: (node: FileTrieNode) => {
    const hidden = new Set(["tags"])
    const segment = node.slugSegment ?? ""
    return !hidden.has(segment)
  },
  sortFn: (a: FileTrieNode, b: FileTrieNode) => {
    const orderMap: Record<string, string[]> = {
      java: [
        "primitive-and-reference-types",
        "class-interface-enum-record",
        "equals-and-hashcode",
        "exception-handling",
        "generics-and-type-erasure",
        "collection-selection",
        "hashmap",
        "sorting-dedup-search-cost",
        "stream-and-optional",
        "java-version-features",
        "reflection-and-annotation",
        "jvm-memory-structure",
        "java-concurrency-basics",
        "java-memory-model",
        "gc-and-tuning",
        "memory-leak-and-oom",
        "serialization-and-jackson",
      ],
      kotlin: [
        "kotlin-why-backend",
        "kotlin-null-safety",
        "kotlin-data-class-and-immutability",
        "kotlin-collection-and-scope-functions",
        "kotlin-java-interop",
        "kotlin-coroutines-basics",
      ],
      jpa: [
        "why-jpa",
        "entity-table-mapping",
        "persistence-context",
        "dirty-checking",
        "association-mapping",
        "lazy-and-eager-loading",
        "n-plus-one-and-fetch-join",
        "transaction-and-flush",
        "querydsl",
        "querydsl-practical-usage",
      ],
      spring: [
        "why-spring",
        "ioc-and-di",
        "bean-lifecycle-and-scope",
        "aop",
        "spring-mvc-request-flow",
        "validation-and-exception-handling",
        "transaction-integration",
        "configuration-and-profile",
      ],
      database: [
        "why-rdb",
        "table-and-key",
        "db-index",
        "execution-plan",
        "transaction-and-isolation",
        "lock",
        "join",
        "pagination-and-bulk-query",
      ],
      network: [
        "http-basics",
        "tcp-connection",
        "timeout",
        "retry",
        "status-code",
        "dns",
        "load-balancer",
        "cors",
        "tls",
        "websocket",
      ],
      os: [
        "process-and-thread",
        "context-switching",
        "memory",
        "cpu-scheduling",
        "file-io",
        "socket-io",
        "blocking-and-non-blocking",
        "system-resource-monitoring",
      ],
      redis: [
        "why-redis",
        "cache-aside-and-ttl",
        "redis-failure-and-fallback",
        "redis-distributed-lock",
        "redis-data-structures",
        "redis-key-and-memory",
        "redis-monitoring",
      ],
      "01-core": [
        "java",
        "kotlin",
        "spring",
        "jpa",
        "database",
        "redis",
        "network",
        "os",
      ],
      "02-practical-backend": [
        "transaction",
        "concurrency",
        "idempotency",
        "performance",
        "observability",
        "architecture",
        "batch",
        "security",
        "testing",
        "ci-cd",
      ],
      transaction: [
        "why-transaction",
        "acid-and-isolation",
        "transaction-boundary",
        "spring-transaction",
        "lock-and-deadlock",
        "external-api-and-transaction",
        "compensation-and-outbox",
      ],
      concurrency: [
